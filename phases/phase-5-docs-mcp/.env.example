# Copy this file to .env and fill in your values.

PULSE_DB_PATH=data/pulse.db
PULSE_LOG_LEVEL=INFO
PULSE_PRODUCTS_FILE=products.yaml
PULSE_MAX_LLM_COST_USD=1.0
PULSE_MAX_TOKENS_PER_RUN=100000
PULSE_CONFIRM_SEND=false
PULSE_RANDOM_SEED=42
PULSE_EMBEDDING_PROVIDER=openai
PULSE_LIVE_NETWORK=false

# --- Phase 3 LLM settings ---
PULSE_LLM_PROVIDER=groq
PULSE_LLM_MODEL=llama-3.3-70b-versatile
# PULSE_GROQ_API_KEY=gsk_...
# PULSE_ANTHROPIC_API_KEY=sk-ant-...
# PULSE_OPENAI_API_KEY=sk-...

# --- Phase 5: Google Docs MCP (FastMCP server via stdio) ---
# Command to launch the FastMCP Docs server as a subprocess.
# Adjust the path to match where services/docs-mcp/server.py lives relative
# to the working directory when you run `pulse publish`.
PULSE_DOCS_MCP_COMMAND=uv run --directory services/docs-mcp python server.py

# Google service-account credentials JSON (single-line, base64 or raw JSON string).
# Required by services/docs-mcp/server.py at runtime.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
