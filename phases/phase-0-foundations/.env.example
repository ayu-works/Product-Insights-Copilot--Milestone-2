# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.

# Path to the SQLite database file
PULSE_DB_PATH=data/pulse.db

# Logging level: DEBUG, INFO, WARNING, ERROR
PULSE_LOG_LEVEL=INFO

# Path to the products config file
PULSE_PRODUCTS_FILE=products.yaml

# LLM cost hard cap per run (USD)
PULSE_MAX_LLM_COST_USD=1.0

# LLM token hard cap per run
PULSE_MAX_TOKENS_PER_RUN=100000

# Set to true to actually send emails (default: draft only)
PULSE_CONFIRM_SEND=false

# Random seed for reproducible clustering
PULSE_RANDOM_SEED=42

# Embedding provider: openai or local
PULSE_EMBEDDING_PROVIDER=openai

# Enable live network calls in tests (default: false, uses fixtures)
PULSE_LIVE_NETWORK=false

# --- LLM / API keys (Phase 3+) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- MCP server commands (Phase 5+) ---
# PULSE_DOCS_MCP_COMMAND=npx @modelcontextprotocol/server-gdocs
# PULSE_GMAIL_MCP_COMMAND=npx @modelcontextprotocol/server-gmail
