{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocSectionRequests",
  "description": "List of Google Docs batchUpdate requests for a weekly pulse section. Phase 5 shifts all indices by (doc_end_index - 1) before calling the API.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": true,
    "oneOf": [
      {
        "required": ["insertText"],
        "properties": {
          "insertText": {
            "type": "object",
            "required": ["location", "text"],
            "properties": {
              "location": {
                "type": "object",
                "required": ["index"],
                "properties": {
                  "index": {"type": "integer", "minimum": 0}
                }
              },
              "text": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        }
      },
      {
        "required": ["updateParagraphStyle"],
        "properties": {
          "updateParagraphStyle": {
            "type": "object",
            "required": ["range", "paragraphStyle", "fields"],
            "properties": {
              "range": {
                "type": "object",
                "required": ["startIndex", "endIndex"],
                "properties": {
                  "startIndex": {"type": "integer", "minimum": 0},
                  "endIndex":   {"type": "integer", "minimum": 1}
                },
                "additionalProperties": false
              },
              "paragraphStyle": {"type": "object"},
              "fields":         {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      {
        "required": ["createParagraphBullets"],
        "properties": {
          "createParagraphBullets": {
            "type": "object",
            "required": ["range", "bulletPreset"],
            "properties": {
              "range": {
                "type": "object",
                "required": ["startIndex", "endIndex"],
                "properties": {
                  "startIndex": {"type": "integer", "minimum": 0},
                  "endIndex":   {"type": "integer", "minimum": 1}
                },
                "additionalProperties": false
              },
              "bulletPreset": {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      {
        "required": ["updateTextStyle"],
        "properties": {
          "updateTextStyle": {
            "type": "object",
            "required": ["range", "textStyle", "fields"],
            "properties": {
              "range": {
                "type": "object",
                "required": ["startIndex", "endIndex"],
                "properties": {
                  "startIndex": {"type": "integer", "minimum": 0},
                  "endIndex":   {"type": "integer", "minimum": 1}
                },
                "additionalProperties": false
              },
              "textStyle": {"type": "object"},
              "fields":    {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      {
        "required": ["insertTable"],
        "properties": {
          "insertTable": {
            "type": "object",
            "required": ["location", "rows", "columns"],
            "properties": {
              "location": {
                "type": "object",
                "required": ["index"],
                "properties": {
                  "index": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": false
              },
              "rows":    {"type": "integer", "minimum": 1},
              "columns": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": false
          }
        }
      }
    ]
  }
}
