# Copy this file to .env and fill in your values.

PULSE_DB_PATH=data/pulse.db
PULSE_LOG_LEVEL=INFO
PULSE_PRODUCTS_FILE=products.yaml
PULSE_MAX_LLM_COST_USD=1.0
PULSE_MAX_TOKENS_PER_RUN=100000
PULSE_RANDOM_SEED=42
PULSE_EMBEDDING_PROVIDER=openai
PULSE_LIVE_NETWORK=false

# --- Phase 3 LLM settings ---
PULSE_LLM_PROVIDER=groq
PULSE_LLM_MODEL=llama-3.3-70b-versatile
# PULSE_GROQ_API_KEY=gsk_...
# PULSE_ANTHROPIC_API_KEY=sk-ant-...
# PULSE_OPENAI_API_KEY=sk-...

# --- Phase 5: Google Docs MCP (FastMCP server via stdio) ---
PULSE_DOCS_MCP_COMMAND=uv run --directory services/docs-mcp python server.py

# --- Phase 6: Gmail MCP (FastMCP server via stdio) ---
PULSE_GMAIL_MCP_COMMAND=uv run --directory services/gmail-mcp python server.py

# Set to true to actually send emails (default: draft only).
# WARNING: Setting this to true in a backfill scenario will send one email per
# past week. Each run's idempotency check prevents true duplicates within a week.
PULSE_CONFIRM_SEND=false

# Google credentials JSON (single-line) — used by both MCP servers at runtime.
# Provide either a service-account key or a user OAuth credentials file.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# For service accounts sending Gmail (requires domain-wide delegation):
# GMAIL_DELEGATED_EMAIL=you@yourdomain.com
