# ============================================================
#  Shared .env for ALL phases — copy this to phases/.env
#  and fill in your values.
#
#  All phases load .env files in this priority order:
#    project-root/.env  <  phases/.env  <  phases/phase-X/.env
#  Later file wins on conflict, so you can override any value
#  at the phase level without touching this file.
# ============================================================


# ── Database & core ──────────────────────────────────────────
PULSE_DB_PATH=data/pulse.db
PULSE_LOG_LEVEL=INFO
PULSE_PRODUCTS_FILE=products.yaml
PULSE_RANDOM_SEED=42
PULSE_LIVE_NETWORK=false
# Embedding provider for clustering: "local" (sentence-transformers,
# BAAI/bge-small-en-v1.5, no API key needed) or "openai" (needs PULSE_OPENAI_API_KEY)
PULSE_EMBEDDING_PROVIDER=local


# ── LLM (Phase 3) ─────────────────────────────────────────────
PULSE_LLM_PROVIDER=groq
PULSE_LLM_MODEL=llama-3.3-70b-versatile
PULSE_MAX_LLM_COST_USD=1.0
PULSE_MAX_TOKENS_PER_RUN=100000

# PULSE_GROQ_API_KEY=gsk_...
# PULSE_ANTHROPIC_API_KEY=sk-ant-...
# PULSE_OPENAI_API_KEY=sk-...


# ── Phase 5 — Google Docs MCP ────────────────────────────────
#
# How to get GOOGLE_CREDENTIALS_JSON (OAuth user token — easiest for testing):
#
#   1. Go to https://console.cloud.google.com/
#   2. Create a project (or reuse one).
#   3. Enable APIs: "Google Docs API" and "Google Drive API".
#   4. Go to APIs & Services → Credentials → Create Credentials
#      → OAuth client ID → Desktop app.
#   5. Download the client_secret_*.json file.
#   6. Run the one-time auth flow to get a token:
#
#        pip install google-auth-oauthlib
#        python -c "
#        from google_auth_oauthlib.flow import InstalledAppFlow
#        import json, pathlib
#        SCOPES = [
#            'https://www.googleapis.com/auth/documents',
#            'https://www.googleapis.com/auth/drive',
#        ]
#        flow = InstalledAppFlow.from_client_secrets_file('client_secret_*.json', SCOPES)
#        creds = flow.run_local_server(port=0)
#        token = json.loads(creds.to_json())
#        pathlib.Path('google_token.json').write_text(json.dumps(token))
#        print('Saved to google_token.json')
#        "
#
#   7. The token JSON is a dict with keys: token, refresh_token, token_uri,
#      client_id, client_secret, scopes.
#      Paste the entire one-line JSON as the value below.
#
# GOOGLE_CREDENTIALS_JSON={"token":"ya29.xxx","refresh_token":"1//xxx","token_uri":"https://oauth2.googleapis.com/token","client_id":"xxx.apps.googleusercontent.com","client_secret":"xxx","scopes":["https://www.googleapis.com/auth/documents","https://www.googleapis.com/auth/drive"]}

# Command to launch the FastMCP Docs server as a stdio subprocess.
# Run this from inside phases/phase-5-docs-mcp/ or phases/phase-6-gmail-mcp/
PULSE_DOCS_MCP_COMMAND=uv run --directory services/docs-mcp python server.py


# ── Phase 6 — Gmail MCP ──────────────────────────────────────
#
# Same GOOGLE_CREDENTIALS_JSON as above — add Gmail scopes to the OAuth flow:
#   'https://www.googleapis.com/auth/gmail.send'
#   'https://www.googleapis.com/auth/gmail.compose'
#   'https://www.googleapis.com/auth/gmail.modify'
#   'https://www.googleapis.com/auth/gmail.labels'
#   'https://www.googleapis.com/auth/gmail.readonly'
#
# Re-run the auth flow above with the expanded SCOPES list if you need Gmail too.

PULSE_GMAIL_MCP_COMMAND=uv run --directory services/gmail-mcp python server.py

# Set to true only when you want to actually send (not just draft).
PULSE_CONFIRM_SEND=false

# Service accounts only — the Gmail user to impersonate (domain-wide delegation).
# Leave blank if using user OAuth credentials.
# GMAIL_DELEGATED_EMAIL=you@yourdomain.com
